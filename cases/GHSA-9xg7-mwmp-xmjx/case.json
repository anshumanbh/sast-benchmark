  "advisory": {
    "title": "Staff Token permission bypass",
    "severity": "high",
    "publishedAt": "2026-01-08T14:37:41Z",
    "description": "Ghost's staff-token authentication flow could reach endpoints intended only for staff-session authentication, giving external systems broader access than intended. The issue affected Ghost v5.121.0 through v5.130.5 and Ghost v6.0.0 through v6.10.3, and was fixed in v5.130.6 and v6.11.0.",
    "cweIds": [
      "CWE-863"
    ],
