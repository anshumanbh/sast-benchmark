  "advisory": {
    "title": "Unauthorized Newsletter Modification",
    "severity": "high",
    "publishedAt": "2022-11-28T15:06:43Z",
    "description": "Members could modify newsletter settings they were not meant to control because of a validation gap for nested objects in the Members API. The issue affected Ghost v4.46.0 through v4.48.7 and Ghost v5.0.0 through v5.22.6, and was fixed in v4.48.8 and v5.22.7.",
    "cweIds": [
      "CWE-284"
    ],
